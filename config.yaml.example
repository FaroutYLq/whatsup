# ArXiv Daily Digest Configuration File
# Copy this file to config.yaml and fill in your details

# Email Configuration (for sending digest)
email:
  # SMTP server (Gmail: smtp.gmail.com)
  smtp_server: smtp.gmail.com
  
  # SMTP port (Gmail: 587 for TLS)
  smtp_port: 587
  
  # Your email address (sender)
  from_email: your.email@gmail.com
  
  # Your email password or app password
  # For Gmail, use an app password (see docs/GMAIL_SETUP.md)
  password: your-app-password-here
  
  # Recipient(s). One address as a plain string, or several as a YAML
  # list (or a comma-separated string). All listed addresses receive
  # the same digest.
  to_email: your.email@gmail.com
  # to_email:
  #   - you@example.edu
  #   - collaborator@example.edu

# ArXiv Configuration
arxiv:
  # List of arXiv categories to monitor
  # Examples: cond-mat.supr-con, physics.ins-det, astro-ph.IM
  # Find categories at: https://arxiv.org/category_taxonomy
  categories:
    - cond-mat.supr-con
    - physics.ins-det
    - astro-ph.IM
  
  # Keywords for pre-filtering (optional COST-SAVER, not a safety net)
  # Only used when keyword_filter is true (see below). When active,
  # only papers whose title/abstract contain one of these words (whole
  # word match) are sent to the LLM.
  keywords:
    - superconductor
    - quasiparticle
    - THz
    - detector
    - photon

  # Whether to hard-filter by keywords before LLM scoring.
  # false (recommended): every fetched paper is scored by the LLM, so
  #   nothing is dropped by a substring miss. Costs more tokens.
  # true: only keyword-matching papers are scored (cheaper, but risks
  #   missing relevant papers that don't contain a listed keyword).
  keyword_filter: false

  # How many days back to search for papers.
  # IMPORTANT: set this LARGER than your run cadence so consecutive
  # runs overlap and no window is lost to a delayed/skipped run. The
  # CI runs every 3 days, so 4-5 gives a safe overlap. Papers already
  # seen simply get re-scored; they are not double-counted within a run.
  max_days_back: 4

# Anthropic (Claude) API Configuration
anthropic:
  # Your Anthropic API key (starts with sk-ant-...)
  # Get one at: https://console.anthropic.com/settings/keys
  api_key: your-anthropic-api-key-here

  # Model to use for evaluation
  # claude-haiku-4-5 is fast + cheap (good for high-volume scoring);
  # use claude-sonnet-5 or claude-opus-4-8 for higher-quality scoring.
  model: claude-haiku-4-5

  # Relevance threshold (0-10)
  # Papers scoring >= this value will be included
  threshold: 7.0
  
  # Max parallel API calls (1-20)
  # Higher = faster but more API load
  # Recommended: 10 for good balance
  max_workers: 10
  
  # Show sample LLM responses for debugging (true/false)
  verbose: false

# Zotero Library Configuration
zotero:
  # Path to your exported Zotero library
  # Supported formats: .bib (BibTeX) or .json
  # See docs/ZOTERO_EXPORT.md for export instructions
  library_file: path/to/your/zotero_export.bib
  
  # Include all paper titles from library (recommended)
  include_all_titles: true
  
  # Number of recent papers to include with full abstracts
  # (remaining papers show titles only for context)
  detailed_papers: 200

# Your Research Interests
interests:
  # Describe your current specific research interests
  # This helps the LLM understand what papers are relevant
  description: |
    Recent specific interests:
    1. Athermal quasiparticle dynamics in disordered
       superconductors
    2. Application of THz single photon detectors in
       particle physics and cosmology
    3. [Add more interests as needed]

